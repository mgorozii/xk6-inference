{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["index.d.ts"],
  "typedocOptions": {
    "entryPoints": ["index.d.ts"],
    "out": "build/docs"
  }
}
